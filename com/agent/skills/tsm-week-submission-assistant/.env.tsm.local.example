# 复制为同目录下 .env.tsm.local 后填写（勿提交）
# 键名与 ipm-ui 前端环境变量 / Cookie 一致

TSM_API_BASE=
# 或 VUE_APP_TSM_API=

P_AUTH=
P_RTOKEN=

VUE_APP_SSO=
VUE_APP_BASE_API_2=

# 可选
# P_COMPANY_ID= / VUE_APP_COMPANY_ID=
# P_APP_ID= / VUE_APP_CENTER_BASE_APP_ID=

# ---------- 路径（Claude 全局技能 / 非仓库内脚本 建议配置）----------
# ipm-ui 仓库根绝对路径；save <list.json> 第二候选、TSM_USE_REPO_ENV 时 .env 查找
# TSM_REPO_ROOT=/path/to/ipm-ui
# 与 TSM_REPO_ROOT 二选一即可
# TSM_WORKSPACE_ROOT=/path/to/ipm-ui

# 技能根目录（默认=脚本所在目录）；.env.tsm.local 放在该目录下
# TSM_SKILL_DIR=/path/to/tsm-week-submission-assistant

# 业务配置 JSON（默认 技能目录/tsm.config.json）；也可用 from-config 第三参指定
# TSM_CONFIG=/path/to/tsm.config.json

# 从 cwd、仓库根等多处尝试 .env.tsm.local（见 SKILL.md）
# TSM_USE_REPO_ENV=1
